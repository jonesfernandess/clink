{
  "name": "clink",
  "version": "1.0.0",
  "description": "Bridge between Claude Code and Telegram — use Claude Code from your phone",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "gateway": "node dist/cli.js gateway",
    "start": "node dist/cli.js gateway"
  },
  "keywords": [
    "claude",
    "telegram",
    "cli",
    "mobile",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bin": {
    "clink": "./dist/cli.js"
  },
  "systemDependencies": {
    "python3": ">= 3.8 (for audio transcription)",
    "faster-whisper": "pip3 install faster-whisper",
    "ffmpeg": "brew install ffmpeg (macOS) / apt install ffmpeg (Linux)"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "node-telegram-bot-api": "^0.67.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
